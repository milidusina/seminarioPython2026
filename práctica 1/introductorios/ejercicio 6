lista1= []
lista2=[]

num = int(input("ingresa un numero:    "))
for i in range(1,num):
    if i%5 == 0:
        lista2.append(i)
        continue
    lista1.append(i)

print("elementos de la lista 1, no multiplos de 5:   ")
for i in range(len(lista1)):
    print(lista1[i])
print("elementos de la lista 2, multiplos de 5:   ")
for i in range(len(lista2)):
    print(lista2[i])
